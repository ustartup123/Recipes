rules_version = '2';

// Per-user isolation pattern: every collection's documents must carry a
// `userId` field, and reads/writes are only allowed when the requesting
// user's UID matches that field. The default-deny rule at the bottom
// prevents any collection without an explicit allow block from being read
// or written from the client.
//
// Add a new block per collection. Example for an `items` collection:
//
//   match /items/{itemId} {
//     allow create: if request.auth != null
//                   && request.auth.uid == request.resource.data.userId;
//     allow read, update, delete: if request.auth != null
//                                 && request.auth.uid == resource.data.userId;
//   }
//
// For per-user singletons keyed by UID (e.g. user settings), key the doc
// path by UID directly:
//
//   match /users/{userId} {
//     allow read, write: if request.auth != null && request.auth.uid == userId;
//   }

service cloud.firestore {
  match /databases/{database}/documents {

    // User settings keyed by UID
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny — every collection must have its own match block above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
